{
  "name": "xbb-desktop",
  "version": "2.2.6",
  "description": "OpenClaw Assistant — Desktop app for managing your WhatsApp AI",
  "author": {
    "name": "xbb",
    "email": "support@cooltechgp.online"
  },
  "main": "dist/electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve & sleep 5 && electron .",
    "build": "ng build --configuration production && tsc -p tsconfig.electron.json",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder --win --mac --linux"
  },
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^19.2.23",
    "@angular/cli": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0"
  }
}
